  <builders>
    <hudson.tasks.Shell>
      <command># no async + debuging outputs for stdout stderr (sector and object tests)
cd ${WORKSPACE}/simulator-ci
git fetch https://review.gerrithub.io/davidsaOpenu/simulator-ci refs/changes/25/283425/2 &amp;&amp; git cherry-pick FETCH_HEAD


cd ${WORKSPACE}/simulator-ci/ansible
set -o pipefail
ansible --version
ansible-playbook  -e &apos;short_mode=false&apos; -i hosts site.yml -vvvv --extra-vars &quot;dest=${WORKSPACE}/simulator&quot; | sed &apos;s/\\n/\n/g&apos; | sed &apos;s/\\t/\t/g&apos;


</command>
    </hudson.tasks.Shell>
