import jenkins.model.Jenkins
import org.jenkinsci.plugins.workflow.job.WorkflowJob
import hudson.model.Result

properties([
    [$class: 'PriorityJobProperty', priority: 1]
])

pipeline {
    agent any

    triggers {
        cron('H/15 * * * *')
    }

    options {
        buildDiscarder(
            logRotator(
                daysToKeepStr: '14',
                numToKeepStr: '24'
            )
        )
        timeout(time: 10, unit: 'MINUTES')
        timestamps()
        disableConcurrentBuilds()
    }


    stages {
        stage('xv6-test-image build') {
            steps {
                script {
                    sh '''
                        echo "================================================================="
                        echo "Run xv6-test-image build to save time and prevent xv6 job timeout"
                        rm -rf xv6
                        git clone "https://review.gerrithub.io/davidsaOpenu/xv6"
                        cd xv6
                        docker build --build-arg USERNAME=$(whoami) \
                                     --build-arg GRPNAME=$(id -gn) \
                                     --build-arg UID=$(id -u) \
                                     --build-arg GID=$(id -g) \
                                     -t xv6-test-image .
                    '''
                }
            }
        }

        stage('Extract Pipeline Failure Reasons') {
            steps {
                script {
                    def getFailureReason = { build ->
                        if (build.result == Result.SUCCESS) return "Success"
                        if (build.result == Result.ABORTED) return "Aborted by user/system"

                        // Check build causes (e.g., SCM trigger, upstream, user)
                        def causes = build.getCauses()
                        def causeDesc = causes ? causes.collect { it.getShortDescription() }.join(", ") : "Unknown cause"

                        // Attempt to parse Build Actions for errors (like Pipeline stage errors)
                        def actionError = ""
                        build.getActions().each { action ->
                            if (action.class.name.contains("Flow Causes") || action.class.name.contains("ErrorAction")) {
                                actionError += " | Error: ${action.toString()}"
                            }
                        }

                        // Fallback to checking the last few lines of console log for common failures
                        def log = build.getLog(30).join("\n")
                        def reason = "Failed. Cause: ${causeDesc}${actionError}"

                        if (log.contains("fatal") || log.contains("Error:")) {
                            reason += " | Check console for fatal/error markers."
                        }

                        return reason
                    }

                    println("=== Extracting Failure Reasons for last 14 builds of Pipeline Jobs ===")

                    Jenkins.instance.getAllItems(WorkflowJob.class).each { job ->
                        println("\nJob: ${job.fullName}")

                        def builds = job.getBuilds().limit(14)

                        builds.each { build ->
                            def status = build.result ?: "RUNNING"
                            if (status != Result.SUCCESS) {
                                def reason = getFailureReason(build)
                                println("  -> Build #${build.number} [${status}]: ${reason}")
                            }
                        }
                    }

                    println("\n=== Extraction Complete ===")
                }
            }
        }

        stage('Stop docker containers run > 5h') {
            steps {
                script {
                    sh '''
                        echo "====================================================="
                        echo "Stop docker containers that are running more them 5 h"

                        current_timestamp=$(date +%s)

                        containers=$(docker ps --format "{{.ID}}\t{{.CreatedAt}}")

                        while IFS=$'\t' read -r container_id created_at; do
                            echo "Remove the +0300 IDT portion from the container creation timestamp"
                            created_at=$(echo "$created_at" | awk '{print $1, $2}')

                            echo "Convert the container creation time to a timestamp"
                            created_timestamp=$(date -d "$created_at" +%s 2>/dev/null)

                            if [ -z "$created_timestamp" ]; then
                                echo "Failed to parse container creation time: $created_at"
                                continue
                            fi

                            time_difference=$((current_timestamp - created_timestamp))

                            if [ "$time_difference" -gt 18000 ]; then # 5h=18000secs
                                docker stop "$container_id" | true

                                docker rm "$container_id" | true

                                echo "Stopped and removed container: $container_id"
                            fi
                        done <<< "$containers"
                    '''
                }
            }
        }

        stage('Force remove stopped container images') {
            steps {
                script {
                    sh '''
                        echo "======================================================"
                        echo "Force remove images associated with stopped containers"
                        docker images --quiet --filter=dangling=true | xargs --no-run-if-empty docker rmi -f
                    '''
                }
            }
        }

    }

    post {
        always {
            script {
                sh '''
                    echo "==================== post stage - always  ===================="

                '''
            }
        }
    }
}
